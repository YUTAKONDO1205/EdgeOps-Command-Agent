# ──────────────────────────────────────────────────────────────────────
# Secrets / environment
# ──────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# Azure / cloud credentials
.azure/
azure.json

# ──────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
develop-eggs/
.installed.cfg
pip-log.txt
pip-delete-this-directory.txt
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Jupyter
.ipynb_checkpoints/

# mypy / pyright / ruff caches
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/
.pyrightconfig.json.bak

# ──────────────────────────────────────────────────────────────────────
# Streamlit / app runtime
# ──────────────────────────────────────────────────────────────────────
.streamlit/secrets.toml
_uploaded_image.*
_tmp_*

# ──────────────────────────────────────────────────────────────────────
# Verification artifacts (do NOT commit)
# Screenshots, snapshots, recordings produced while QA-ing the UI.
# These regenerate on every test run and are not part of the product.
# ──────────────────────────────────────────────────────────────────────
.playwright-mcp/
playwright-report/
test-results/
*.har
screenshots/
*-snapshot.yml
page-*.png
page-*.jpeg
page-*.jpg

# Allow real product assets to be committed even though the rule above
# matches generic image patterns — see negation below.
!assets/*.jpg
!assets/*.png

# ──────────────────────────────────────────────────────────────────────
# IDE / editor
# ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ──────────────────────────────────────────────────────────────────────
# OS
# ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
ehthumbs.db
*.lnk

# Windows Office lock files
~$*

# ──────────────────────────────────────────────────────────────────────
# Logs / temp
# ──────────────────────────────────────────────────────────────────────
*.log
logs/
*.tmp
*.temp
*.bak

# ──────────────────────────────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────────────────────────────
.docker/

# ──────────────────────────────────────────────────────────────────────
# Node (only if a frontend is added later)
# ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# BBOX verification artefacts (regenerated by tools/bbox_verify.py)
output/bbox_check/*.png

# ──────────────────────────────────────────────────────────────────────
# Submission notes — keep local only (do not upload edits to git)
# ──────────────────────────────────────────────────────────────────────
SUBMISSION.md
